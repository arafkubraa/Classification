#include "Process.h" // C-tarzı fonksiyon bildirimleri (Z_Score_Parameters)
#include <cmath>
#include <vector>
#include <numeric>
#include <algorithm> 

// NOT: Bu dosyada Pybind11 kütüphanelerine (pybind11/pybind11.h, py::array_t) gerek yoktur.

// Train_Perceptron_Binary_C fonksiyonunun tam tanımı
// Bu fonksiyon, Process.h'de bildirilen ve wrapper.cpp'de çağrılan fonksiyondur.
void Train_Perceptron_Binary_C(float* samples, float* targets, 
                               float* weights, float* bias, 
                               int numSample, int inputDim,
                               float* mean_out, float* std_out,
                               float* normalized_samples_out,
                               float* epoch_errors_out, int* epochs_run_out)
{
    // 1. Z-Score Parametrelerini Hesaplama ve Çıktı Pointer'larına Kaydetme
    // Z_Score_Parameters fonksiyonu, mean_out ve std_out'u günceller.
    Z_Score_Parameters(samples, numSample, inputDim, mean_out, std_out);

    // 2. Normalizasyon ve Etiket Dönüşümü İçin Geçici Bellek
    // adjustedTargets yerel olarak kullanılır, normalized_samples_out ise geri döndürülür.
    float* adjustedTargets = new float[numSample];
    
    for (int i = 0; i < numSample; ++i) {
        // Normalizasyon
        for (int d = 0; d < inputDim; ++d) {
            float std_val = (std_out[d] != 0.0f) ? std_out[d] : 1.0f;
            normalized_samples_out[i * inputDim + d] = (samples[i * inputDim + d] - mean_out[d]) / std_val;
        }
        // Etiket Dönüşümü (+1.0f veya -1.0f)
        adjustedTargets[i] = (targets[i] == 1.0f) ? 1.0f : -1.0f;
    }

    // 3. Perceptron Eğitim Mantığı
    float total_err, net, out;
    float lrn_cnst = 0.1f;
    int max_iter = 10000;
    int epoch = 0;
    bool learned = false;

    // Bias değerini yerel olarak kopyala (sadece tek bias değeri kullanılır)
    float bias_copy = bias[0]; 

    while (!learned && epoch < max_iter) {
        total_err = 0.0f;
        epoch++;
        

        for (int k = 0; k < numSample; k++) {
            const float* current_sample = normalized_samples_out + k * inputDim; 

            // İleri Besleme (Forward Pass)
            net = bias_copy; 
            for (int i = 0; i < inputDim; i++) {
                net += weights[i] * current_sample[i];
            }
            
            // Aktivasyon
            out = (net > 0.0f) ? 1.0f : -1.0f;

            // Hata ve Geri Yayılım
            float err = adjustedTargets[k] - out;

            if (std::fabs(err) > 1e-6f) {
                // Ağırlık Güncellemesi
                for (int i = 0; i < inputDim; i++) {
                    weights[i] += lrn_cnst * err * current_sample[i];
                }
                bias_copy += lrn_cnst * err;
            }

            total_err += std::fabs(err);
        }

        // Her epoch'un toplam hatasını diziye kaydet
        epoch_errors_out[epoch - 1] = total_err;

        if (total_err < 1e-6f) {
            learned = true;
        }
    }

    // Eğitilmiş bias değerini orijinal pointer'a geri yaz
    *epochs_run_out = epoch;
    bias[0] = bias_copy; 

    // Yerel olarak tahsis edilen belleği temizle
    delete[] adjustedTargets;
}